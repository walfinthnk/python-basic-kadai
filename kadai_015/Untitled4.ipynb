      "source": [
        "class Human:\n",
        "    def __init__(self, name, age):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "\n",
        "    def printinfo(self, name, age):\n",
        "        print(f\"name: {name}, age: {age}\")\n",
        "\n",
        "human = Human(\"侍太郎\", 48)\n",
        "human.printinfo(\"侍太郎\", 48)"
      ],
